<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  <!-- Static store pages -->
  <url>
    <loc>https://www.jellojam.com/store</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://www.jellojam.com/store/catalog</loc>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://www.jellojam.com/store/membership</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  <url>
    <loc>https://www.jellojam.com/store/journal</loc>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
  <url>
    <loc>https://www.jellojam.com/store/news</loc>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>
  <url>
    <loc>https://www.jellojam.com/store/order-tracking</loc>
    <changefreq>yearly</changefreq>
    <priority>0.4</priority>
  </url>

  <!--
    Product pages (/store/product/:id) and journal posts (/store/journal/:slug)
    are dynamic. Generate a separate sitemap for them via a build-time script or
    a Supabase Edge Function that queries products + journal_posts and outputs XML.

    Suggested endpoint: GET /functions/v1/sitemap-dynamic
    Reference it here with a <sitemap> element once implemented:

    <sitemap>
      <loc>https://www.jellojam.com/sitemap-products.xml</loc>
    </sitemap>
  -->

</urlset>
